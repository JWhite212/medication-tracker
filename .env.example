# Required
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Optional: OAuth (enables "Continue with Google/GitHub" buttons)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: Email (enables email reminders and password reset)
RESEND_API_KEY=

# Optional: Cron authentication
CRON_SECRET=

# Optional: Data encryption
ENCRYPTION_KEY=

# Optional: Web Push notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
