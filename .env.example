# MedTracker environment variables
# Copy this file to .env and fill in the values you need.
# Anything marked "optional" can be left blank — the related feature
# will be disabled at runtime.

# === Required ===

# Postgres connection string (Neon, Supabase, RDS, local docker, etc).
# Use ?sslmode=require for managed providers.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# === OAuth (optional) ===
# Enables "Continue with Google" / "Continue with GitHub" on the login page.
# Leave blank to hide those buttons.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Email (optional) ===
# Required for password reset, email verification, and email reminders.
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=

# Sender address for outgoing email. Format: "Display Name <addr@domain.tld>".
# Defaults to a placeholder — set this to a verified Resend domain in production.
EMAIL_FROM=MedTracker <noreply@example.com>

# Public base URL of the deployed app, used to build links inside emails
# (password reset, email verification). Falls back to the request origin
# when unset, but should be set explicitly in production.
# Example: https://medication-tracker-jw.vercel.app
PUBLIC_BASE_URL=

# === Cron (optional) ===
# Shared secret for the /api/cron/reminders endpoint. Vercel Cron sends
# this in the Authorization header. Generate any random 32+ char string.
CRON_SECRET=

# === Encryption (recommended in production) ===
# Used to encrypt TOTP secrets at rest (and any future at-rest secrets).
# Must remain stable across deploys — rotating it invalidates 2FA for
# every user. Generate once with: openssl rand -base64 48
ENCRYPTION_KEY=

# === Web Push (optional) ===
# Generate with: npx web-push generate-vapid-keys
# Required for browser push notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact email surfaced to push services (RFC 8292).
VAPID_EMAIL=

# === Feature flags (optional) ===
# Drug-interaction checking via OpenFDA. Marked experimental in the UI;
# leave unset to disable the feature entirely.
INTERACTIONS_ENABLED=false
